{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "executable": "build/empty_project.elf",
            "request": "launch",
            "type": "cortex-debug",
            "gdbPath": "/opt/RISCV_Tools/CH32/RISC-V Embedded GCC15/bin/riscv32-wch-elf-gdb",
            "servertype": "openocd",
            "serverArgs": [
                "-d3"
            ],
            "serverpath": "/opt/RISCV_Tools/CH32/OpenOCD/bin/openocd",
            "configFiles": [
                "/opt/RISCV_Tools/CH32/OpenOCD/share/openocd/scripts/interface/wch-riscv.cfg"
            ],
            "svdFile": "device/ch32v307/svd/CH32V307xx.svd",
            "liveWatch": {
                "enabled": false
            },
            "preLaunchTask": "Run All Tasks",
            "runToEntryPoint": "main",
            "postDebugTask": "Monitor resume"
        }
    ]
}